{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./"
    },
    "include": [
        "tests/**/*.ts",
        "pages/**/*.ts",
        "components/**/*.ts",
        "modals/**/*.ts",
        "fixtures/**/*.ts",
        "utils/**/*.ts",
        "auth/**/*.ts",
        "playwright.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}